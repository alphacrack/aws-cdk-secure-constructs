{
  "name": "aws-cdk-secure-constructs",
  "version": "1.0.0",
  "description": "Secure-by-default AWS CDK constructs with property injection and CIS-verified compliance reports",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib",
    ".jsii"
  ],
  "stability": "stable",
  "scripts": {
    "build": "jsii",
    "build:watch": "jsii --watch",
    "package": "jsii-pacmak",
    "api-diff": "jsii-diff npm:$npm_package_name",
    "watch": "jsii --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:local-build": "bash scripts/test-local-build.sh",
    "release": "bash scripts/release.sh",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" \"examples/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"test/**/*.ts\" \"examples/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"examples/*.ts\" \"**/*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"examples/*.ts\"",
    "prepublishOnly": "npm run build",
    "cdk": "cdk",
    "cdk:synth": "cdk synth",
    "cdk:deploy": "cdk deploy",
    "cdk:destroy": "cdk destroy",
    "prepare": "husky",
    "pre-commit": "lint-staged",
    "clean": "rm -rf lib dist coverage .jsii tsconfig.tsbuildinfo"
  },
  "keywords": [
    "aws",
    "cdk",
    "constructs",
    "security",
    "blueprints",
    "infrastructure",
    "typescript"
  ],
  "author": {
    "name": "alphacrack",
    "url": "https://github.com/alphacrack"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alphacrack/aws-cdk-secure-constructs.git"
  },
  "bugs": {
    "url": "https://github.com/alphacrack/aws-cdk-secure-constructs/issues"
  },
  "homepage": "https://github.com/alphacrack/aws-cdk-secure-constructs#readme",
  "jsii": {
    "outdir": "dist",
    "versionFormat": "short",
    "targets": {
      "python": {
        "distName": "aws-cdk-secure-constructs",
        "module": "aws_cdk_secure_constructs"
      },
      "java": {
        "package": "io.github.example.securecdk",
        "maven": {
          "groupId": "io.github.example",
          "artifactId": "aws-cdk-secure-constructs"
        }
      },
      "dotnet": {
        "namespace": "Example.SecureCdk",
        "packageId": "Example.SecureCdk"
      }
    },
    "tsc": {
      "outDir": "lib",
      "rootDir": "src"
    },
    "excludeTypescript": [
      "examples",
      "test"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nrwl/workspace": "^19.8.4",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.8.10",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "aws-cdk": "^2.1126.0",
    "aws-cdk-lib": "2.259.0",
    "constructs": "10.6.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jsii": "^5.4.0",
    "jsii-diff": "^1.103.0",
    "jsii-pacmak": "^1.103.0",
    "lint-staged": "^15.0.2",
    "nx": "19.8.4",
    "prettier": "^3.0.3",
    "ts-jest": "^29.1.1",
    "typescript": "~6.0.3"
  },
  "peerDependencies": {
    "aws-cdk-lib": "^2.196.0",
    "constructs": "^10.3.0"
  },
  "bundledDependencies": [],
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "nx": {}
}
