#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "${YELLOW}🔍 Running pre-commit checks...${NC}"

# Only check files staged for commit
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|js|json|md)$')

if [ -z "$STAGED_FILES" ]; then
    echo "${YELLOW}⚠️  No staged files to check${NC}"
    exit 0
fi

echo "${YELLOW}📁 Staged files:${NC}"
echo "$STAGED_FILES"

# 1. Lint + format staged files (eslint --fix, prettier --write)
echo "${YELLOW}🔧 Running lint-staged...${NC}"
if ! npm run pre-commit; then
    echo "${RED}❌ lint-staged failed${NC}"
    exit 1
fi

# The remaining checks only matter when TypeScript changed.
if echo "$STAGED_FILES" | grep -q '\.ts$'; then
    # 2. jsii type-check / compile
    echo "${YELLOW}🏗️  Building (jsii)...${NC}"
    if ! JSII_SILENCE_WARNING_UNTESTED_NODE_VERSION=1 npm run build; then
        echo "${RED}❌ Build failed${NC}"
        exit 1
    fi

    # 3. Full test suite (fast) incl. verified CIS compliance tests
    echo "${YELLOW}🧪 Running tests...${NC}"
    if ! npm test; then
        echo "${RED}❌ Tests failed${NC}"
        exit 1
    fi
fi

echo "${GREEN}✅ Pre-commit checks completed successfully!${NC}"
